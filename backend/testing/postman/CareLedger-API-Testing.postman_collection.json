{
  "info": {
    "name": "CareVault API Testing",
    "description": "Automated API checks for report evidence: positive, validation, auth, and data checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response success=true', function () { pm.expect(body.success).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "02 Signup Validation - Missing Fields",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{new_user_email}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "signup"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
              "const body = pm.response.json();",
              "pm.test('Error envelope present', function () { pm.expect(body.success).to.eql(false); pm.expect(body.error).to.be.an('object'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "03 Signup Positive",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{new_user_email}}\",\n  \"phone\": \"{{new_user_phone}}\",\n  \"plain_password\": \"{{new_user_password}}\",\n  \"role\": \"patient\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "signup"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 or 409 (if already exists)', function () { pm.expect([201, 409]).to.include(pm.response.code); });",
              "const body = pm.response.json();",
              "pm.test('Valid envelope', function () { pm.expect(body.success).to.be.a('boolean'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 Login Positive - Patient",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"patient\",\n  \"email\": \"{{patient_email}}\",\n  \"plain_password\": \"{{patient_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Token received', function () { pm.expect(body.data.token).to.be.a('string').and.not.empty; });",
              "pm.environment.set('patient_token', body.data.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "05 Login Negative - Wrong Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"patient\",\n  \"email\": \"{{patient_email}}\",\n  \"plain_password\": \"wrong-password-123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
    {
      "name": "06 Auth Negative - Patients Endpoint Without Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "patients"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    },
    {
      "name": "07 Patients Get Own Profile - Authorized",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{patient_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "patients"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or 404 (if profile not created yet)', function () { pm.expect([200, 404]).to.include(pm.response.code); });"
            ]
          }
        }
      ]
    },
    {
      "name": "08 Patients Create Profile Validation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{patient_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"Report Test Patient\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/patients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "patients"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400', function () { pm.response.to.have.status(400); });"
            ]
          }
        }
      ]
    },
    {
      "name": "09 Users Get By Id - Not Found",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{missing_user_id}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "{{missing_user_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404', function () { pm.response.to.have.status(404); });"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ]
}
