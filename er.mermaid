    class R_HAS_PATIENT,R_HAS_DOCTOR,R_RUNS_CLINIC,R_BOOKS,R_CONDUCTS,R_GENERATES_RX,R_HAS_ITEMS,R_TRACKS_MEDS,R_HAS_ALLERGIES,R_HAS_CONDITIONS,R_HAS_EMERGENCY,R_GRANTS_ACCESS relation